<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Black Header with BMI Score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR RESULT"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.25"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvBmiScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/tvBmiCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#DDDDDD"
                android:letterSpacing="0.05"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Divider accent line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#222222" />

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="28dp">

            <!-- User Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="4dp"
                app:cardBackgroundColor="#F4F4F4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvHeightWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#555555" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BMI Ranges Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI RANGES"
                android:textSize="11sp"
                android:textColor="#999999"
                android:letterSpacing="0.2"
                android:layout_marginBottom="14dp" />

            <!-- Underweight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#CCCCCC" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Underweight"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginStart="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt; 18.5"
                    android:textSize="14sp"
                    android:textColor="#777777" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#E8E8E8"
                android:layout_marginBottom="12dp" />

            <!-- Normal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#000000" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Normal"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginStart="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18.5 – 24.9"
                    android:textSize="14sp"
                    android:textColor="#777777" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#E8E8E8"
                android:layout_marginBottom="12dp" />

            <!-- Overweight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#888888" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Overweight"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginStart="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25.0 – 29.9"
                    android:textSize="14sp"
                    android:textColor="#777777" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#E8E8E8"
                android:layout_marginBottom="12dp" />

            <!-- Obese -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="36dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#444444" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Obese"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginStart="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="≥ 30.0"
                    android:textSize="14sp"
                    android:textColor="#777777" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="RECALCULATE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#000000"
                android:letterSpacing="0.1" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
