<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvQuizTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="General Knowledge Quiz"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Question 1 -->
            <TextView
                android:id="@+id/tvQuestion1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. What is the capital of France?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <RadioGroup
                android:id="@+id/rgQuestion1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb1_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="London"/>
                <RadioButton android:id="@+id/rb1_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Berlin"/>
                <RadioButton android:id="@+id/rb1_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Paris"/>
                <RadioButton android:id="@+id/rb1_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Madrid"/>
            </RadioGroup>

            <!-- Question 2 -->
            <TextView
                android:id="@+id/tvQuestion2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Which planet is known as the Red Planet?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <RadioGroup
                android:id="@+id/rgQuestion2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb2_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Venus"/>
                <RadioButton android:id="@+id/rb2_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mars"/>
                <RadioButton android:id="@+id/rb2_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Jupiter"/>
                <RadioButton android:id="@+id/rb2_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Saturn"/>
            </RadioGroup>

            <!-- Question 3 -->
            <TextView
                android:id="@+id/tvQuestion3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. What is the largest ocean on Earth?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <RadioGroup
                android:id="@+id/rgQuestion3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb3_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Atlantic Ocean"/>
                <RadioButton android:id="@+id/rb3_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Indian Ocean"/>
                <RadioButton android:id="@+id/rb3_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Arctic Ocean"/>
                <RadioButton android:id="@+id/rb3_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pacific Ocean"/>
            </RadioGroup>

            <!-- Question 4 -->
            <TextView
                android:id="@+id/tvQuestion4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Who wrote 'Hamlet'?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <RadioGroup
                android:id="@+id/rgQuestion4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb4_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Charles Dickens"/>
                <RadioButton android:id="@+id/rb4_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="William Shakespeare"/>
                <RadioButton android:id="@+id/rb4_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mark Twain"/>
                <RadioButton android:id="@+id/rb4_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Leo Tolstoy"/>
            </RadioGroup>

            <!-- Question 5 -->
            <TextView
                android:id="@+id/tvQuestion5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. What is the chemical symbol for Gold?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <RadioGroup
                android:id="@+id/rgQuestion5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb5_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Gd"/>
                <RadioButton android:id="@+id/rb5_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ag"/>
                <RadioButton android:id="@+id/rb5_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Au"/>
                <RadioButton android:id="@+id/rb5_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Fe"/>
            </RadioGroup>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>